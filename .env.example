# ============================================
# WAPIFY - Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in values

# ============================================
# APP CONFIG
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================
# DATABASE (Supabase)
# ============================================
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=xxxxx
DATABASE_URL=postgresql://user:pass@host:5432/db

# ============================================
# AUTHENTICATION (Nostr NIP-07 first, NextAuth optional fallback)
# ============================================
# Used to sign session JWTs after NIP-07 challenge verification.
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# ============================================
# NOSTR (NIP-07 login + relays)
# ============================================
# Comma-separated list of default relays to read kind:0 profiles + write events
NEXT_PUBLIC_NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band
# Optional: server-side relay for verifying signed events
NOSTR_VERIFY_RELAY=wss://relay.damus.io

# ============================================
# WAPU (Payment Processor)
# ============================================
WAPU_CLIENT_ID=your_wapu_client_id
WAPU_CLIENT_SECRET=your_wapu_client_secret
WAPU_API_KEY=your_wapu_api_key
WAPU_WEBHOOK_SECRET=your_wapu_webhook_secret
NEXT_PUBLIC_WAPU_REDIRECT_URI=http://localhost:3000/api/auth/wapu/callback

# ============================================
# EMAIL (optional, for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@wapify.io

# ============================================
# LOGGING & DEBUG
# ============================================
DEBUG=false
LOG_LEVEL=info

# ============================================
# NODE ENV
# ============================================
NODE_ENV=development
