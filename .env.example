# ============================================
# WAPUFY - Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in values

# ============================================
# APP CONFIG
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================
# DATABASE (Supabase)
# ============================================
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=xxxxx
DATABASE_URL=postgresql://user:pass@host:5432/db

# ============================================
# AUTHENTICATION (Nostr NIP-07 first, NextAuth optional fallback)
# ============================================
# Used to sign session JWTs after NIP-07 challenge verification.
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# ============================================
# NOSTR (NIP-07 login + relays)
# ============================================
# Comma-separated list of default relays to read kind:0 profiles + write events
NEXT_PUBLIC_NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band
# Optional: server-side relay for verifying signed events
NOSTR_VERIFY_RELAY=wss://relay.damus.io

# ============================================
# WAPU (Lightning Address checkout — see https://wapu.shiafu.com)
# ============================================
# Wapu API base. Use staging while developing, prod when live.
#   Staging: https://be-stage.wapu.app
#   Prod:    https://be-prod.wapu.app
WAPU_API_BASE=https://be-stage.wapu.app

# Username del vendedor demo (Lightning Address: <user>@wapu.app).
# La tienda /store/demo cobra a este username via LNURL-pay.
WAPU_DEMO_SELLER=lacrypta

# (Opcional, futuro) API key del vendedor para acciones autenticadas
# (rates server-side, listar transacciones, etc). Generada en /users/api-token.
# Wapufy NO la necesita para el flow de checkout (LNURL-pay es público).
WAPU_API_KEY=

# ============================================
# EMAIL (optional, for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@wapufy.io

# ============================================
# LOGGING & DEBUG
# ============================================
DEBUG=false
LOG_LEVEL=info

# ============================================
# NODE ENV
# ============================================
NODE_ENV=development
