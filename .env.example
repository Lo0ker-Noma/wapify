# ============================================
# WAPIFY - Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in values

# ============================================
# APP CONFIG
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================
# DATABASE (Supabase)
# ============================================
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=xxxxx
DATABASE_URL=postgresql://user:pass@host:5432/db

# ============================================
# AUTHENTICATION
# ============================================
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# ============================================
# HUAPI (Payment Processor)
# ============================================
HUAPI_CLIENT_ID=your_huapi_client_id
HUAPI_CLIENT_SECRET=your_huapi_client_secret
HUAPI_API_KEY=your_huapi_api_key
HUAPI_WEBHOOK_SECRET=your_huapi_webhook_secret
NEXT_PUBLIC_HUAPI_REDIRECT_URI=http://localhost:3000/api/auth/huapi/callback

# ============================================
# EMAIL (optional, for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@wapify.io

# ============================================
# LOGGING & DEBUG
# ============================================
DEBUG=false
LOG_LEVEL=info

# ============================================
# NODE ENV
# ============================================
NODE_ENV=development
